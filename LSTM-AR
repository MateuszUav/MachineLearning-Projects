# ============================================================
# 2. AR MODEL  (linear least-squares)
# ============================================================
print("\n" + "=" * 60)
print("2. LINEAR AUTOREGRESSIVE (AR) MODEL")
print("=" * 60)

TRAIN_RATIO = 0.80
TRAIN_END = int(TRAIN_RATIO * N)


def build_ar_dataset(prices, p):
    """Return (X, y) where X[i] = [y_{t-1}…y_{t-p}], y[i] = y_t."""
    n = len(prices) - p
    X = np.column_stack([prices[p - k - 1: n + p - k - 1] for k in range(p)])
    y = prices[p:]
    return X, y


AR_ORDERS = [1, 3, 5, 10, 20, 50]
ar_results = {}

for p in AR_ORDERS:
    X_all, y_all = build_ar_dataset(prices, p)
    t = TRAIN_END - p          # training rows

    X_tr, y_tr = X_all[:t], y_all[:t]
    X_te, y_te = X_all[t:], y_all[t:]

    # Add bias column
    X_tr_b = np.c_[X_tr, np.ones(len(X_tr))]
    X_te_b = np.c_[X_te, np.ones(len(X_te))]

    coeffs, _, _, _ = np.linalg.lstsq(X_tr_b, y_tr, rcond=None)

    y_hat_tr = X_tr_b @ coeffs
    y_hat_te = X_te_b @ coeffs

    mse_tr = mean_squared_error(y_tr, y_hat_tr)
    mse_te = mean_squared_error(y_te, y_hat_te)
    r2_te  = r2_score(y_te, y_hat_te)

    ar_results[p] = dict(
        coeffs=coeffs,
        mse_tr=mse_tr, mse_te=mse_te,
        rmse_te=np.sqrt(mse_te), r2_te=r2_te,
        y_te=y_te, y_hat_te=y_hat_te,
    )
    print(f"AR({p:2d}): train MSE={mse_tr:.4f}  test MSE={mse_te:.4f}"
          f"  RMSE={np.sqrt(mse_te):.4f}  R²={r2_te:.4f}")

# Zero-cost baseline: y_{t+1} = y_t
y_base_actual = prices[TRAIN_END + 1:]
y_base_pred   = prices[TRAIN_END:-1]
mse_base = mean_squared_error(y_base_actual, y_base_pred)
r2_base  = r2_score(y_base_actual, y_base_pred)
print(f"\nBaseline (y_{{t+1}}=y_t): test MSE={mse_base:.4f}"
      f"  RMSE={np.sqrt(mse_base):.4f}  R²={r2_base:.4f}")

best_p = min(ar_results, key=lambda p: ar_results[p]["mse_te"])
print(f"\nBest AR order by test MSE: AR({best_p})")

# Residual analysis
residuals = ar_results[best_p]["y_te"] - ar_results[best_p]["y_hat_te"]


def acf(x, nlags=40):
    x = x - x.mean()
    c = np.correlate(x, x, mode="full")
    c = c[len(x) - 1:]
    return c[:nlags + 1] / c[0]


fig, axes = plt.subplots(1, 3, figsize=(15, 4))
axes[0].plot(ar_results[best_p]["y_te"], label="Actual", alpha=0.7)
axes[0].plot(ar_results[best_p]["y_hat_te"], label=f"AR({best_p})", alpha=0.7)
axes[0].set_title(f"AR({best_p}) – Test Set")
axes[0].legend()
axes[1].plot(residuals)
axes[1].axhline(0, color="r", linestyle="--")
axes[1].set_title("Residuals")
ci = 1.96 / np.sqrt(len(residuals))
r_acf = acf(residuals)
axes[2].stem(r_acf, markerfmt="C0o", linefmt="C0-", basefmt="k-")
axes[2].axhline(ci, color="r", linestyle="--", label="95% CI")
axes[2].axhline(-ci, color="r", linestyle="--")
axes[2].set_title("ACF of Residuals")
axes[2].legend()
plt.tight_layout()
plt.savefig("2_ar_model.png", dpi=100)
print("Saved: 2_ar_model.png")

plt.figure(figsize=(8, 4))
orders = sorted(ar_results.keys())
plt.plot(orders, [ar_results[p]["mse_te"] for p in orders], "o-", label="AR")
plt.axhline(mse_base, color="r", linestyle="--", label="Baseline")
plt.xlabel("AR order p")
plt.ylabel("Test MSE")
plt.title("AR Model: Test MSE vs Lag Order")
plt.legend()
plt.tight_layout()
plt.savefig("2_ar_mse_vs_order.png", dpi=100)
print("Saved: 2_ar_mse_vs_order.png")

