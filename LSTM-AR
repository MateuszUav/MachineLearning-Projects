print("=" * 60)
print("1. DATASET")
print("=" * 60)

# data.txt: 2110 rows x 4 columns
#   col 0 – y_t  (current close price)
#   col 1 – y_{t-1}, col 2 – y_{t-2}, col 3 – y_{t-3}
# The company is represented by this historical price series.

data = np.loadtxt("data.txt")
prices = data[:, 0]          # full price time series (2110 points)
N = len(prices)

print(f"Observations : {N}")
print(f"Price range  : [{prices.min():.4f}, {prices.max():.4f}]")
print(f"Mean / Std   : {prices.mean():.4f} / {prices.std():.4f}")

